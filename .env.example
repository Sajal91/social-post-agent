# Server
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/socialpostagent

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key

# WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# Public URL (ngrok in dev, deployed URL in prod)
PUBLIC_BASE_URL=https://your-ngrok-url.ngrok.io

# React client CORS
CLIENT_URL=http://localhost:5173

# Set to true to skip real social posting during testing
POSTING_DRY_RUN=true

# Facebook
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# Instagram (uses Facebook page token)
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# LinkedIn (optional — skipped if empty)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORGANIZATION_URN=urn:li:organization:12345678
