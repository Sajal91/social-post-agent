# Server
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/socialpostagent

# Auth & encryption (platform-level)
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
ENCRYPTION_KEY=change-me-to-a-strong-secret-key

# Initial admin (created on first startup if no admin exists)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=automationhub.admin@123
ADMIN_NAME=Admin

# Email (optional — not used for auth currently)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com

# Public URL (ngrok in dev, deployed URL in prod) — set per user in admin panel
PUBLIC_BASE_URL=https://your-ngrok-url.ngrok.io

# React client CORS
CLIENT_URL=http://localhost:5173

# Per-user credentials (Gemini, WhatsApp, Facebook, Instagram, LinkedIn)
# are configured in the admin dashboard — not in this file.
